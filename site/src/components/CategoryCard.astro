---
interface Props {
  ikon: string;
  nev: string;
  leiras: string;
  href: string;
}
const { ikon, nev, leiras, href } = Astro.props;
---
<a
  href={href}
  class="group bg-white border border-gray-200 rounded-xl p-5 hover:border-blue-400 hover:shadow-md transition-all flex flex-col items-center text-center"
>
  <div class="text-4xl mb-3 group-hover:scale-110 transition-transform">{ikon}</div>
  <div class="font-semibold text-gray-800 mb-1">{nev}</div>
  <div class="text-sm text-gray-500 leading-snug">{leiras}</div>
</a>
