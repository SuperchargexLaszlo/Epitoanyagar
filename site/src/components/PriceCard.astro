---
interface Props {
  min: number;
  max: number;
  atlag: number;
  egyseg: string;
}
const { min, max, atlag, egyseg } = Astro.props;

const tartomany = max - min;
const aranyAtlag = (atlag - min) / tartomany;
const szin = aranyAtlag < 0.33
  ? { bg: 'bg-green-50', border: 'border-green-300', text: 'text-green-800', badge: 'bg-green-100 text-green-700' }
  : aranyAtlag < 0.66
  ? { bg: 'bg-yellow-50', border: 'border-yellow-300', text: 'text-yellow-800', badge: 'bg-yellow-100 text-yellow-700' }
  : { bg: 'bg-red-50', border: 'border-red-300', text: 'text-red-800', badge: 'bg-red-100 text-red-700' };
---
<div class={`rounded-xl border-2 ${szin.border} ${szin.bg} p-5 mb-6`}>
  <div class="flex items-start justify-between">
    <div>
      <div class="text-sm font-medium text-gray-600 mb-1">Átlagár 2026</div>
      <div class={`text-3xl font-bold ${szin.text}`}>
        {atlag.toLocaleString('hu-HU')} Ft
      </div>
      <div class="text-sm text-gray-500 mt-1">{egyseg}</div>
    </div>
    <div class={`text-xs font-semibold px-2 py-1 rounded-full ${szin.badge}`}>
      {min.toLocaleString('hu-HU')} – {max.toLocaleString('hu-HU')} Ft
    </div>
  </div>
</div>
