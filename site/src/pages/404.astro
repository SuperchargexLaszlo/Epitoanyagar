---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Az oldal nem található – epitoanyagar.hu"
  description="A keresett oldal nem található. Térj vissza a főoldalra és keress rá az építőanyag árára."
  canonicalURL="https://epitoanyagar.hu/404/"
>
  <div class="max-w-2xl mx-auto px-4 py-24 text-center">
    <div class="text-8xl font-bold text-gray-200 mb-4">404</div>
    <h1 class="text-2xl font-bold text-gray-800 mb-3">Az oldal nem található</h1>
    <p class="text-gray-600 mb-8">A keresett oldal nem létezik vagy áthelyezték. Keresd meg a kívánt építőanyag árát a főoldalon.</p>
    <a
      href="/"
      class="inline-block bg-blue-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors"
    >
      Vissza a főoldalra
    </a>
    <div class="mt-10 text-sm text-gray-500">
      <p class="mb-3 font-medium">Legkeresettebb árak:</p>
      <div class="flex flex-wrap justify-center gap-2">
        <a href="/cement-ara/" class="text-blue-600 hover:underline">Cement ára</a>
        <a href="/tegla-ara/" class="text-blue-600 hover:underline">Tégla ára</a>
        <a href="/gipszkarton-ara/" class="text-blue-600 hover:underline">Gipszkarton ára</a>
        <a href="/terko-ara/" class="text-blue-600 hover:underline">Térkő ára</a>
        <a href="/kozetgyapot-ara/" class="text-blue-600 hover:underline">Kőzetgyapot ára</a>
        <a href="/beton-ara/" class="text-blue-600 hover:underline">Beton ára</a>
      </div>
    </div>
  </div>
</BaseLayout>
